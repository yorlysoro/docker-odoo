<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Product Form to add tags -->
    <record id="view_product_template_form_inherit_tags" model="ir.ui.view">
        <field name="name">product.template.form.inherit.tags</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="stock_operation_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
            </xpath>
        </field>
    </record>

    <!-- Kanban View custom action for grouping by tags (Avoiding N+1 natively in Odoo 18) -->
    <record id="view_product_template_kanban_tags" model="ir.ui.view">
        <field name="name">product.template.kanban.tags</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//main[hasclass('pe-2')]" position="inside">
                <div class="mt-1">
                    <field name="stock_operation_tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Quick Server Action for Mass Edit -->
    <record id="action_assign_tags_multi" model="ir.actions.server">
        <field name="name">Mass Assign Operation Tags</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,kanban</field>
        <field name="state">code</field>
        <field name="code">
# Opens a window or executes inline. In list view, Odoo 18 handles M2M edits natively.
# This hook remains for custom complex logic routing if needed in the future.
action = env.ref('product_tags_dynamic.action_stock_operation_tag').read()[0]
        </field>
    </record>
</odoo>