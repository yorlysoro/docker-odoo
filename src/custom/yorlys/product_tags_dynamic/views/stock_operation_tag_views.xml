<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_stock_operation_tag_form" model="ir.ui.view">
        <field name="name">stock.operation.tag.form</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <form string="Operation Tag">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. Fragile, Cold Chain..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="operation_type" widget="badge" 
                                   decoration-info="operation_type == 'receipt'"
                                   decoration-warning="operation_type == 'delivery'"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View (Odoo 18 standard uses <list> instead of <tree>) -->
    <record id="view_stock_operation_tag_list" model="ir.ui.view">
        <field name="name">stock.operation.tag.list</field>
        <field name="model">stock.operation.tag</field>
        <field name="arch" type="xml">
            <list string="Operation Tags" editable="bottom">
                <field name="name"/>
                <field name="operation_type"/>
                <field name="color" widget="color_picker"/>
            </list>
        </field>
    </record>

    <!-- Action & Menu -->
    <record id="action_stock_operation_tag" model="ir.actions.act_window">
        <field name="name">Operation Tags</field>
        <field name="res_model">stock.operation.tag</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Create your first operational tag!
          </p>
        </field>
    </record>

    <menuitem id="menu_stock_operation_tag" 
              name="Operation Tags" 
              parent="stock.menu_stock_config_settings" 
              action="action_stock_operation_tag" 
              sequence="110"/>
</odoo>