<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_discount_rule_form" model="ir.ui.view">
        <field name="name">pos.discount.rule.form</field>
        <field name="model">pos.discount.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="E.g., Happy Hour Lunch"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="hour_from" widget="float_time"/>
                            <field name="hour_to" widget="float_time"/>
                        </group>
                        <group>
                            <field name="discount_percentage"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pos_discount_rule_list" model="ir.ui.view">
        <field name="name">pos.discount.rule.list</field>
        <field name="model">pos.discount.rule</field>
        <field name="arch" type="xml">
            <list string="Discount Rules">
                <field name="name"/>
                <field name="hour_from" widget="float_time"/>
                <field name="hour_to" widget="float_time"/>
                <field name="discount_percentage"/>
            </list>
        </field>
    </record>

    <record id="action_pos_discount_rule" model="ir.actions.act_window">
        <field name="name">Discount Rules</field>
        <field name="res_model">pos.discount.rule</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <menuitem id="menu_pos_discount_rule"
              name="Discount Rules"
              parent="point_of_sale.menu_point_config_product"
              action="action_pos_discount_rule"
              sequence="30"/>
</odoo>