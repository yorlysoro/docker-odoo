<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_account_collection_alert_rule_form" model="ir.ui.view">
        <field name="name">account.collection.alert.rule.form</field>
        <field name="model">account.collection.alert.rule</field>
        <field name="arch" type="xml">
            <form string="Collection Rule">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="e.g. High Risk > 30 Days"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="risk_level"
                                   decoration-danger="risk_level == 'high'"
                                   decoration-warning="risk_level == 'medium'"
                                   decoration-info="risk_level == 'low'"/>
                            <field name="days_overdue"/>
                        </group>
                        <group>
                            <field name="amount_min"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_account_collection_alert_rule_list" model="ir.ui.view">
        <field name="name">account.collection.alert.rule.list</field>
        <field name="model">account.collection.alert.rule</field>
        <field name="arch" type="xml">
            <list string="Collection Rules">
                <field name="name"/>
                <field name="days_overdue"/>
                <field name="amount_min"/>
                <field name="risk_level" widget="badge" 
                       decoration-danger="risk_level == 'high'"
                       decoration-warning="risk_level == 'medium'"
                       decoration-info="risk_level == 'low'"/>
            </list>
        </field>
    </record>

    <!-- Action & Menu -->
    <record id="action_account_collection_alert_rule" model="ir.actions.act_window">
        <field name="name">Collection Rules</field>
        <field name="res_model">account.collection.alert.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_account_collection_alert_rule" 
              name="Collection Rules" 
              parent="account.menu_finance_configuration" 
              action="action_account_collection_alert_rule" 
              sequence="150"/>
</odoo>