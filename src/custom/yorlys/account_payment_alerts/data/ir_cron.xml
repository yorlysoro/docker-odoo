<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Daily cron job to evaluate invoice risks -->
        <record id="ir_cron_evaluate_collection_risk" model="ir.cron">
            <field name="name">Account: Evaluate Collection Risks</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="state">code</field>
            <field name="code">model._cron_evaluate_collection_risk()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>