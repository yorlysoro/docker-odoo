<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_fiscal_profile" model="ir.ui.view">
        <field name="name">res.partner.form.fiscal.profile</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="fiscal_profile_id" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>