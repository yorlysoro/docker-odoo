<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Fiscal Profiles -->
    <record id="view_account_fiscal_profile_tree" model="ir.ui.view">
        <field name="name">account.fiscal.profile.tree</field>
        <field name="model">account.fiscal.profile</field>
        <field name="arch" type="xml">
            <list string="Fiscal Profiles" decoration-muted="not active">
                <field name="name"/>
                <field name="description" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Form View for Fiscal Profiles -->
    <record id="view_account_fiscal_profile_form" model="ir.ui.view">
        <field name="name">account.fiscal.profile.form</field>
        <field name="model">account.fiscal.profile</field>
        <field name="arch" type="xml">
            <form string="Fiscal Profile">
                <sheet>
                    <!-- Standard active ribbon for archived records -->
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Special Taxpayer" required="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Internal notes or legal references regarding this profile..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Fiscal Profiles -->
    <record id="action_account_fiscal_profile" model="ir.actions.act_window">
        <field name="name">Fiscal Profiles</field>
        <field name="res_model">account.fiscal.profile</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Fiscal Profile!
            </p>
            <p>
                Fiscal profiles allow you to categorize partners (customers/vendors) 
                to automatically apply withholding taxes during invoice validation.
            </p>
        </field>
    </record>

    <!-- Menu Item (Under Accounting > Configuration) -->
    <!-- Restricted to accounting managers to prevent unauthorized changes -->
    <menuitem id="menu_account_fiscal_profile"
              name="Fiscal Profiles"
              parent="account.menu_finance_configuration"
              action="action_account_fiscal_profile"
              groups="account.group_account_manager"
              sequence="100"/>
</odoo>