<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View for Withholding Rules -->
    <record id="view_account_withholding_rule_tree" model="ir.ui.view">
        <field name="name">account.withholding.rule.tree</field>
        <field name="model">account.withholding.rule</field>
        <field name="arch" type="xml">
            <list string="Withholding Rules">
                <field name="profile_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="tax_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <!-- Form View for Withholding Rules -->
    <record id="view_account_withholding_rule_form" model="ir.ui.view">
        <field name="name">account.withholding.rule.form</field>
        <field name="model">account.withholding.rule</field>
        <field name="arch" type="xml">
            <form string="Withholding Rule">
                <sheet>
                    <div class="oe_title">
                        <label for="profile_id" class="oe_edit_only" string="Profile Rule for"/>
                        <h2>
                            <field name="profile_id" placeholder="Select a fiscal profile..." options="{'no_create': True}"/>
                        </h2>
                    </div>
                    
                    <group>
                        <group name="rule_configuration" string="Configuration">
                            <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        </group>
                        
                        <group name="rule_taxes" string="Applied Withholdings">
                            <!-- Only show negative taxes to avoid user mistakes -->
                            <field name="tax_ids" widget="many2many_tags" 
                                   domain="[('amount', '&lt;=', 0), ('company_id', '=', company_id)]"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Withholding Rules -->
    <record id="action_account_withholding_rule" model="ir.actions.act_window">
        <field name="name">Withholding Rules</field>
        <field name="res_model">account.withholding.rule</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first Withholding Rule!
            </p>
            <p>
                Map a Fiscal Profile to specific negative taxes (withholdings) 
                for a particular company.
            </p>
        </field>
    </record>

    <!-- Menu Item (Under Accounting > Configuration) -->
    <!-- Sequenced right after the profiles menu -->
    <menuitem id="menu_account_withholding_rule"
              name="Withholding Rules"
              parent="account.menu_finance_configuration"
              action="action_account_withholding_rule"
              groups="account.group_account_manager"
              sequence="101"/>
</odoo>